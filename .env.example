# App chạy 100% local cho OCR + parse: không cần API key.
# Lưu quiz: data/quizzes/*.json
# Dev: npm run dev  |  Điện thoại: npm run build && npm run preview:host
#
# Ollama (tuỳ chọn): URL gốc API, mặc định http://127.0.0.1:11434
# OLLAMA_HOST=http://127.0.0.1:11434
#
# OCR API Token (thay thế Tesseract OCR)
# Thay YOUR_API_KEY_HERE bằng token thực tế từ nhà cung cấp OCR
# VITE_API_KEY=YOUR_API_KEY_HERE
